# UNANIMO AI — Environment Configuration
# Copy this file to .env and fill in your API keys

# ── Local Ollama (preferred when set) ─────────────────────────────────────────
# Ollama HTTP API (same host/port as `curl http://HOST:11434/api/tags`).
# Unset defaults to http://192.168.1.130:11434 (lab). Use http://plunder:11434 if your hostname routes correctly.
# If you use docker compose: do NOT set http://127.0.0.1:11434 unless Ollama runs inside the same container —
# 127.0.0.1 there is the app container. For Ollama on the machine running Docker Desktop, use
# http://host.docker.internal:11434 (or leave a wrong localhost value: the app rewrites it when /.dockerenv exists).
# For Ollama on another machine (lab), use that host/IP here.
# Set to - or none to use only cloud API keys below.
OLLAMA_BASE_URL=http://192.168.1.130:11434
# Use OpenAI-compatible POST /v1/chat/completions instead of native /api/chat
# (needed for some proxies and gateways)
# OLLAMA_OPENAI_COMPAT=true
# Optional Bearer if your compat endpoint requires it
# OLLAMA_OPENAI_COMPAT_KEY=
# Seconds: HTTP client timeout per Ollama /api/chat call (large models + GPU queue). Default 900.
# OLLAMA_HTTP_TIMEOUT=900
# Serial vs parallel players: unset or true = one model at a time (best for one GPU). false = all at once.
# OLLAMA_SERIAL_PLAYERS=false
# Default tag when a per-slot model is not set (must exist on the server: ollama list)
OLLAMA_DEFAULT_MODEL=llama3.2
# Optional per UI column (same domain.ModelID slots as before)
# OLLAMA_MODEL_GPT4O=llama3.2
# OLLAMA_MODEL_CLAUDE=mistral
# OLLAMA_MODEL_GEMINI=qwen2.5
# OLLAMA_MODEL_LLAMA=llama3.1
# OLLAMA_MODEL_CUSTOM=llama3.2
# Judge model (defaults to OLLAMA_DEFAULT_MODEL)
# OLLAMA_JUDGE_MODEL=llama3.2

# ── LLM API Keys (cloud — used when OLLAMA_BASE_URL is empty) ─────────────────
# At least one key is required unless Ollama is configured above.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...
GROQ_API_KEY=gsk_...

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional: set a password for Redis in production
REDIS_PASSWORD=
# Docker Compose: host port published for Redis (container still listens on 6379). Default 6380 avoids clashing with a local Redis on 6379.
# REDIS_HOST_PORT=6380

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Docker Compose: host port for the web UI (default 8888; container still listens on 8080 inside the network).
# APP_HOST_PORT=8888
